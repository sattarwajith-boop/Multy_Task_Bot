# Never commit real credentials. Add these in Koyeb Secrets.
BOT_TOKEN=
OWNER_ID=
TELEGRAM_API=
TELEGRAM_HASH=
DATABASE_URL=

# WZML-X leech destination. Use a supergroup/channel where the bot is admin.
LEECH_LOG_ID=
AUTHORIZED_CHATS=
SUDO_USERS=
DEFAULT_UPLOAD=gd
DOWNLOAD_DIR=/usr/src/app/downloads/

# Koyeb health/torrent-selector web process.
BASE_URL=https://{{ KOYEB_PUBLIC_DOMAIN }}
BASE_URL_PORT=8000
PORT=8000
ENABLE_WEB_SERVER=true

# Unified auto-monitor settings.
AUTO_MONITOR_ENABLED=true
AUTO_MONITOR_INTERVAL=900
AUTO_MONITOR_CHAT=
AUTO_MAX_ITEMS_PER_SITE=10
AUTO_LEECH_EXISTING=false
AUTO_FETCH_RETRIES=3
AUTO_FETCH_TIMEOUT=35
AUTO_SITE_COOKIE=
AUTO_SITE_PROXY=
AUTO_FORWARD_CHATS=
MV_SITE_URL=
OMDB_API_KEY=

# Recommended for a small free instance.
BOT_MAX_TASKS=2
QUEUE_ALL=2
TELEGRAM_WORKERS=8
TELEGRAM_TRANSMISSIONS=2
STATUS_UPDATE_INTERVAL=10
RSS_DELAY=900
INCOMPLETE_TASK_NOTIFIER=true
SET_COMMANDS=true
TIMEZONE=Asia/Colombo
